DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain-or-ip
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain-or-ip
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_SAMESITE=None
DJANGO_CSRF_COOKIE_SAMESITE=None
DATABASE_URL=postgresql://neondb_owner:<password>@<neon-host>/neondb?sslmode=require&channel_binding=require
